PORT=4000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=aqbobek-dev-secret
DB_PATH=./data/portal.sqlite

# BilimClass integration
USE_REAL_BILIMCLASS=true
BILIMCLASS_ALLOW_SEED_FALLBACK=true
BILIMCLASS_BASE_URL=https://api.bilimclass.kz
BILIMCLASS_LOGIN_PATH=/api/v2/os/login
BILIMCLASS_DIARY_SUBJECTS_PATH=/api/v4/os/clientoffice/diary/subjects
BILIMCLASS_LOGIN=
BILIMCLASS_PASSWORD=
BILIMCLASS_LOGIN_PAYLOAD_JSON=
BILIMCLASS_LOGIN_HEADERS_JSON={"Origin":"https://bilimclass.kz"}
BILIMCLASS_REQUEST_HEADERS_JSON={"Origin":"https://bilimclass.kz"}
BILIMCLASS_TOKEN=
BILIMCLASS_SCHOOL_ID=15997
BILIMCLASS_EDU_YEAR=2025
BILIMCLASS_PERIOD=4
BILIMCLASS_PERIOD_TYPE=quarter
BILIMCLASS_GROUP_ID=
BILIMCLASS_GROUP_ID_BY_CLASS_JSON={}
BILIMCLASS_GROUP_ID_BY_STUDENT_JSON={}
BILIMCLASS_SCHOOL_ID_BY_CLASS_JSON={}
BILIMCLASS_SCHOOL_ID_BY_STUDENT_JSON={}
BILIMCLASS_STUDENTS_JSON=[]
BILIMCLASS_TIMEOUT_MS=10000

# OpenAI integration
OPENAI_API_KEY=
OPENAI_TIMEOUT_MS=15000
OPENAI_SUMMARY_STEP_TIMEOUT_MS=10000
OPENAI_MENTOR_STEP_TIMEOUT_MS=10000
LLM_SUMMARY_MAX_WAIT_MS=40000

# Local LLM fallback (OpenAI -> local LLM -> demo)
LOCAL_LLM_ENABLED=true
LOCAL_LLM_URL=http://127.0.0.1:8009
LOCAL_LLM_TIMEOUT_MS=20000
LOCAL_LLM_SUMMARY_TIMEOUT_MS=20000
LOCAL_LLM_MENTOR_TIMEOUT_MS=20000
